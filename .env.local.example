# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/council

# ─── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://yourapp.com
NEXT_PUBLIC_APP_URL=https://yourapp.com

# ─── Auth (NextAuth / Auth.js v5) ──────────────────────────────────────────────
AUTH_SECRET=replace-with-a-long-random-string   # openssl rand -base64 32

# OAuth providers (add the ones you want; remove any unused)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# Credentials (admin email/password login)
# Set AUTH_ENABLE_CREDENTIALS=true to allow in production (off by default)
AUTH_ENABLE_CREDENTIALS=false
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=replace-with-a-strong-password

# ─── AI / LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...           # Gemini embeddings
GEMINI_API_KEY=...           # alias used by gemini.ts
OPENAI_API_KEY=...           # optional

# ─── Search ────────────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=...     # optional, for web_search tool

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...        # or sk_test_... for test mode
STRIPE_WEBHOOK_SECRET=whsec_...     # from Stripe webhook endpoint settings
STRIPE_PRO_PRICE_ID=price_...       # recurring monthly price ID

# ─── Contact ───────────────────────────────────────────────────────────────────
CONTACT_EMAIL=you@yourdomain.com    # used in API polite-pool headers
